<UserControl xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:GarthImgLab.ViewModels.Tabs"
    x:Class="GarthImgLab.Views.Tabs.ColorTabView"
    x:DataType="vm:ColorTabVm">
    <Grid Margin="16"
        RowDefinitions="*,14,*,14,*,14,*,14,*"
        ColumnDefinitions="60,14,100,14,144">
        <CheckBox Content="启用"
            IsChecked="{Binding Enabled}"/>
        <ComboBox Grid.Row="0"
            Grid.Column="2"
            ItemsSource="{Binding SaturateModes, Mode=OneTime}"
            DisplayMemberBinding="{Binding Value, Mode=OneTime}"
            SelectedValue="{Binding SelMode}"
            SelectedValueBinding="{Binding Key, Mode=OneTime}"/>
        <NumericUpDown Grid.Row="0"
            Grid.Column="4"
            InnerLeftContent="C 增益"
            Minimum="-1"
            Maximum="1"
            Increment=".01"
            FormatString="0.####"
            Value="{Binding CGain}"/>
        <Slider Grid.Row="2"
            Grid.Column="0"
            Grid.ColumnSpan="5"
            Minimum="-1"
            SmallChange=".1"
            LargeChange="1"
            Value="{Binding CGain}"/>
        <Slider Grid.Row="4"
            Grid.Column="0"
            Grid.ColumnSpan="3"
            SmallChange=".01"
            LargeChange=".1"
            Value="{Binding RGain}"/>
        <NumericUpDown Grid.Row="4"
            Grid.Column="4"
            InnerLeftContent="R 增益"
            Minimum="0"
            Maximum="1"
            Increment=".01"
            FormatString="0.####"
            Value="{Binding RGain}"/>
        <Slider Grid.Row="6"
            Grid.Column="0"
            Grid.ColumnSpan="3"
            SmallChange=".01"
            LargeChange=".1"
            Value="{Binding GGain}"/>
        <NumericUpDown Grid.Row="6"
            Grid.Column="4"
            InnerLeftContent="G 增益"
            Minimum="0"
            Maximum="1"
            Increment=".01"
            FormatString="0.####"
            Value="{Binding GGain}"/>
        <Slider Grid.Row="8"
            Grid.Column="0"
            Grid.ColumnSpan="3"
            SmallChange=".01"
            LargeChange=".1"
            Value="{Binding BGain}"/>
        <NumericUpDown Grid.Row="8"
            Grid.Column="4"
            InnerLeftContent="B 增益"
            Minimum="0"
            Maximum="1"
            Increment=".01"
            FormatString="0.####"
            Value="{Binding BGain}"/>
    </Grid>
</UserControl>

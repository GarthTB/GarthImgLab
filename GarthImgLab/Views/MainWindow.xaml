<Window x:Class="GarthImgLab.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:tabs="clr-namespace:GarthImgLab.Views.Tabs"
    xmlns:vm="clr-namespace:GarthImgLab.VMs"
    d:DataContext="{d:DesignInstance vm:MainVM}"
    mc:Ignorable="d"
    Title="GarthImgLab 1.0.2"
    FontSize="14"
    UseLayoutRounding="True"
    ResizeMode="CanMinimize"
    SizeToContent="WidthAndHeight">
    <TabControl Padding="0"
        SelectedIndex="{Binding TabIdx, Mode=OneWayToSource}">
        <TabItem Header="文件">
            <Grid Height="240">
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition Height="52"/>
                </Grid.RowDefinitions>
                <ListBox Width="480"
                    ToolTip="支持拖放；选中以查看预览"
                    AllowDrop="True"
                    Drop="DropImgPaths"
                    ItemsSource="{Binding ImgPaths}"
                    SelectedItem="{Binding SelImgPath}"/>
                <Grid Row="1"
                    Margin="12,11">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <Button Content="添加"
                        Command="{Binding AddImgCommand}"/>
                    <Button Grid.Column="2"
                        Content="移除"
                        Command="{Binding RemoveImgCommand}"/>
                    <Button Grid.Column="4"
                        Content="预览"
                        Click="ShowPreview"
                        IsEnabled="{Binding Idle}"/>
                    <Button Grid.Column="6"
                        Content="启动"
                        IsEnabled="{Binding Idle}"
                        Command="{Binding RunCommand}"/>
                    <Button Grid.Column="8"
                        Content="打断"
                        Command="{Binding RunCancelCommand}"/>
                </Grid>
            </Grid>
        </TabItem>
        <TabItem Header="饱和度"
            IsEnabled="{Binding Idle}">
            <tabs:SatTab DataContext="{Binding SatTabVM}"/>
        </TabItem>
        <TabItem Header="边框"
            IsEnabled="{Binding Idle}">
            <tabs:FramingTab DataContext="{Binding FramingTabVM}"/>
        </TabItem>
        <TabItem Header="保存"
            IsEnabled="{Binding Idle}">
            <tabs:SavingTab DataContext="{Binding SavingTabVM}"/>
        </TabItem>
    </TabControl>
</Window>
<Application xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:semi="https://irihi.tech/semi"
    xmlns:v="using:GarthImgLab.Views"
    xmlns:vm="using:GarthImgLab.ViewModels"
    x:Class="GarthImgLab.App">
    <Application.Styles>
        <semi:SemiTheme/>
    </Application.Styles>
    <Application.DataTemplates>
        <DataTemplate DataType="vm:FileTabVm">
            <v:FileTabView/>
        </DataTemplate>
        <DataTemplate DataType="vm:SaturateTabVm">
            <v:SaturateTabView/>
        </DataTemplate>
        <DataTemplate DataType="vm:FrameTabVm">
            <v:FrameTabView/>
        </DataTemplate>
        <DataTemplate DataType="vm:SaveTabVm">
            <v:SaveTabView/>
        </DataTemplate>
    </Application.DataTemplates>
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="WindowDefaultBackground"
                        Color="#A000"/>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
